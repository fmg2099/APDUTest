<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/label_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello World!"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center|center_vertical"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/photoView"
            android:layout_width="300dp"
            android:layout_height="300dp"
            app:srcCompat="@drawable/si_autorizo" />

        <TextView
            android:id="@+id/nameLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="15dp"
            android:paddingBottom="15dp"
            android:text="Paco Pérez"
            android:textAlignment="center"
            android:textSize="20sp"
            tools:text="Paco Pérez" />

        <Button
            android:id="@+id/buttonCred1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credencial A"
            tools:text="Credencial A" />

        <Button
            android:id="@+id/buttonCred2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credencial B" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>